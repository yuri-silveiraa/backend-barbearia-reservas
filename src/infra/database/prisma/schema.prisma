generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum UserType {
  BARBER
  CLIENT
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  telephone String
  type      UserType
  provider  String?
  providerId String? @unique
  emailVerified Boolean @default(false)
  emailCode String?
  emailCodeExpires DateTime?
  emailCodeCooldownExpires DateTime?
  profileImageData Bytes?
  profileImageMimeType String?
  createdAt DateTime @default(now())
  barber    Barber? @relation("UserBarber")
  client    Client?  @relation("UserClient")
  customer  Customer? @relation("UserCustomer")
}

model Barber {
  id        String   @id @default(uuid())
  userId    String   @unique
  isAdmin   Boolean  @default(false)
  user      User   @relation("UserBarber", fields: [userId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  appointments Appointment[]
  times     Time[]
}

model Client {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation("UserClient", fields: [userId], references: [id])
  createdAt DateTime @default(now())
  appointments Appointment[]
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  whatsapp  String   @unique
  userId    String?  @unique
  user      User?    @relation("UserCustomer", fields: [userId], references: [id])
  appointments Appointment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  imageData   Bytes?
  imageMimeType String?
  active      Boolean  @default(true)
  appointments Appointment[]
}

model Time {
  id         String   @id @default(uuid())
  disponible Boolean  @default(true)
  date       DateTime
  duration   Int      @default(60)
  barberId   String
  barber     Barber   @relation(fields: [barberId], references: [id])
  appointments Appointment[]
}

model Appointment {
  id         String   @id @default(uuid())
  status     AppointmentStatus @default(SCHEDULED)
  barberId   String
  clientId   String?
  customerId String
  serviceId  String
  timeId     String?
  price      Float
  customerName String
  customerWhatsapp String
  barberName String
  barberWhatsapp String?
  serviceName String
  scheduledAt DateTime
  service    Service    @relation(fields: [serviceId], references: [id])
  client     Client?    @relation(fields: [clientId], references: [id])
  customer   Customer   @relation(fields: [customerId], references: [id])
  barber     Barber     @relation(fields: [barberId], references: [id])
  time       Time?      @relation(fields: [timeId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}
